{
  "$id": "https://mileage-flow-manager.app/task-card.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Card",
  "type": "object",
  "additionalProperties": false,
  "description": "Schema para task-cards em docs/tasks/",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único do card (ex: P1-08)",
      "pattern": "^P[0-9]+(-[A-Z0-9]+)?$"
    },
    "categoria": {
      "type": "string",
      "enum": ["chore", "feat", "fix", "docs", "refactor", "test"],
      "description": "Categoria da tarefa"
    },
    "onda": {
      "type": "string",
      "enum": ["P0", "P1-A", "P1-B", "P2"],
      "description": "Onda/prioridade do roadmap"
    },
    "baseBranch": {
      "type": "string",
      "description": "Branch base para o PR"
    },
    "estado": {
      "type": "string",
      "enum": ["pending", "planned", "implementing", "verified", "review", "done"],
      "description": "Estado atual do card"
    },
    "origem": {
      "type": "string",
      "description": "Origem da task (veredito, issue, etc.)"
    },
    "dependeDe": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Cards dos quais este depende"
    },
    "objetivo": {
      "type": "string",
      "description": "Objetivo principal"
    },
    "naoObjetivos": {
      "type": "string",
      "description": "O que esta tarefa NÃO cobre"
    },
    "criteriosAceite": {
      "type": "string",
      "description": "Critérios de aceite"
    },
    "arquivosPermitidos": {
      "type": "string",
      "description": "Arquivos afetados pela tarefa"
    },
    "riscos": {
      "type": "string",
      "description": "Riscos e invariantes"
    },
    "testesObrigatorios": {
      "type": "string",
      "description": "Testes obrigatórios"
    }
  },
  "required": [
    "id",
    "categoria",
    "onda",
    "baseBranch",
    "estado",
    "origem"
  ]
}
